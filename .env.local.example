# Decap CMS GitHub OAuth 配置
# 在 GitHub 上创建 OAuth App 后填入：https://github.com/settings/developers
# Authorization callback URL 填写：https://你的域名/api/auth

GITHUB_CLIENT_ID=你的_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=你的_github_oauth_app_client_secret

# 后台管理密码（仅服务端）
ADMIN_SECRET=自定义密码

# ─── 生产环境数据持久化（GitHub API）────────────────────────────────
# 仅在部署到 Vercel/serverless 时需要配置；本地开发可留空（会直接读写本地文件）
# 1) 在 GitHub 创建 Personal Access Token（Fine-grained 推荐）
#    权限：Contents = Read and write，仅限本仓库
# 2) 在 Vercel 项目 Environment Variables 添加以下变量
GITHUB_TOKEN=ghp_你的_personal_access_token
GITHUB_REPO=你的GitHub用户名/仓库名
GITHUB_BRANCH=main
# 可选：数据 JSON 在仓库中的路径（默认 src/data）
# GITHUB_DATA_DIR=src/data
